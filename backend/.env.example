# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/ai_telephony?schema=public"

# ──────────────────────────────────────────────
# Smallest.ai (Atoms API)
# ──────────────────────────────────────────────
SMALLEST_AI_API_KEY="sk_your_key_here"
SMALLEST_AI_BASE_URL="https://api.smallest.ai/atoms/v1"

# ──────────────────────────────────────────────
# Webhook Secret (used to verify Smallest.ai payloads)
# ──────────────────────────────────────────────
WEBHOOK_SECRET="your_webhook_secret_here"

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
